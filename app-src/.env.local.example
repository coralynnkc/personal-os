# Copy this to .env.local and fill in values

# Supabase — from your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth gate
AUTH_SECRET=          # openssl rand -hex 32
DASHBOARD_PASSWORD=   # a memorable password you'll type to log in
API_SECRET=           # openssl rand -hex 16

# Google Calendar (optional — calendar card won't render without this)
# Google Calendar → Settings → your calendar → "Secret address in iCal format"
GOOGLE_CALENDAR_ICAL_URL=

# User config
NEXT_PUBLIC_USER_TIMEZONE=America/Los_Angeles   # IANA timezone name (used client- and server-side)
USER_ID=cora                        # any string — used to scope DB rows
